# Example .env (DO NOT commit this file with real credentials)
# Copy this to a file named `.env` and fill in your real values.

MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=vehicle_insurance_db
FLASK_SECRET_KEY=replace_with_a_long_random_secret

# Seeded local users for dashboard login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@12345
REVIEWER_USERNAME=reviewer
REVIEWER_PASSWORD=Reviewer@12345

# Email acknowledgement (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# SMS acknowledgement (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
DEFAULT_SMS_COUNTRY_CODE=+91
